{
  "expo": {
    "name": "GoGourmet",
    "slug": "gogourmet",
    "version": "1.0.0-beta",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gogourmet.app"
    },
    "android": {
      "package": "com.gogourmet.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/splash.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/avatar.png",
      "bundler": "metro"
    },
    "scheme": "gogourmet",
    "plugins": [
      "expo-router",
      "expo-build-properties",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow GoGourmet to use your location to set delivery address.",
          "locationWhenInUsePermission": "Allow GoGourmet to use your location to set delivery address."
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1364470b-a522-4860-b2ba-53288a2c48be"
    }
  }
}
