{
  "$schema": "https://raw.githubusercontent.com/expo/expo/sdk-52/packages/@expo/config/schema/expo-config-schema.json",
  "expo": {
    "name": "GoGourmet",
    "slug": "gogourmet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gogourmet.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gogourmet.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/avatar.png",
      "bundler": "metro"
    },
    "scheme": "gogourmet",
    "plugins": [
      "expo-router",
      "expo-build-properties",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow GoGourmet to use your location to set delivery address.",
          "locationWhenInUsePermission": "Allow GoGourmet to use your location to set delivery address."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#ff6b00"
        }
      ],
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "sentry-expo"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1364470b-a522-4860-b2ba-53288a2c48be"
    }
  }
}
