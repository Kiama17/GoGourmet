{
  "expo": {
    "name": "GoGourmet",
    "slug": "gogourmet",
    "version": "1.0.0-beta",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gogourmet.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gogourmet.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCv33LQCrzbNJnVIwb_uEdVJoqfG0tiV4k"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/avatar.png",
      "bundler": "metro"
    },
    "scheme": "gogourmet",
    "plugins": [
      "expo-router",
      "expo-build-properties",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow GoGourment to use your location to set delivery address.",
          "locationWhenInUsePermission": "Allow GoGourment to use your location to set delivery address."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#ff6b00"
        }
      ],
      "expo-font",
      "expo-image",
      "expo-status-bar"
    ],
    "extra": {
