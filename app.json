{
  "expo": {
    "name": "GoGourment",
    "slug": "gogourment",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/images/logo.png",

    "userInterfaceStyle": "light",

    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ff6b00"
    },

    "assetBundlePatterns": ["**/*"],

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      }
    },

    "web": {
      "bundler": "metro"
    },

    "plugins": ["expo-router"],

    "scheme": "gogourment",

    "experiments": {
      "typedRoutes": true
    }
  }
}
