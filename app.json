{
  "expo": {
    "name": "GoGourment",
    "slug": "gogourment",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/splash.png",
        "backgroundColor": "#ffffff"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCv33LQCrzbNJnVIwb_uEdVJoqfG0tiV4k"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/avatar.png",
      "bundler": "metro"
    },
    "scheme": "gogourment",
    "plugins": [
      "expo-router",
      "expo-build-properties",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow GoGourment to use your location to set delivery address.",
          "locationWhenInUsePermission": "Allow GoGourment to use your location to set delivery address."
        }
      ]
    ],
    "extra": {
