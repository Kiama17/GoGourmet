# APP_ENV is set by the environment-specific file (.env.development/.env.staging/.env.production)
# APP_ENV=development

# Supabase (anon key is safe for client-side use behind RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Amplitude analytics
EXPO_PUBLIC_AMPLITUDE_API_KEY=

# Error monitoring
EXPO_PUBLIC_SENTRY_DSN=

# Google Maps (used by expo-config at build time)
GOOGLE_MAPS_API_KEY=

# NVIDIA NIM (AI recommendations & smart search)
NVIDIA_API_KEY=

# M-Pesa
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=
